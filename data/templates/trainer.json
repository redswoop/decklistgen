{
  "id": "trainer",
  "name": "Trainer",
  "elements": [
    {
      "type": "box",
      "id": "header-banner",
      "props": {
        "anchorX": 20,
        "anchorY": 12,
        "width": 710,
        "direction": "row",
        "skewX": -10,
        "fill": "#1a1a1a",
        "fillOpacity": 1,
        "rx": 18,
        "paddingLeft": 32,
        "paddingRight": 32,
        "paddingTop": 8,
        "paddingBottom": 8,
        "filter": "title-shadow"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Supporter",
            "fontSize": "$trainerType",
            "fontFamily": "trainerHeader",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "wrap": 0,
            "grow": 1,
            "hAlign": "start",
            "vAlign": "middle"
          },
          "bind": {
            "text": "trainerType"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "Trainer",
            "fontSize": 24,
            "fontFamily": "trainerHeader",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 0.7,
            "wrap": 0,
            "hAlign": "end",
            "vAlign": "middle"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "name-cluster",
      "props": {
        "anchorX": 45,
        "anchorY": 86
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Iono",
            "fontSize": "$cardName.trainer",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "_baseName",
            "fill": "_textFill",
            "stroke": "_textStroke"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "subtitle",
      "props": {
        "anchorX": 47,
        "anchorY": 138,
        "direction": "row"
      },
      "showIf": "_subtitle",
      "children": [
        {
          "type": "text",
          "props": {
            "text": "",
            "fontSize": "$subtitle.trainer",
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 0.7,
            "filter": "shadow",
            "wrap": 0,
            "vAlign": "middle"
          },
          "bind": {
            "text": "_subtitle",
            "fill": "_subtleFill"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "content-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 15,
        "paddingRight": 15,
        "paddingBottom": 37,
        "paddingLeft": 15,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 25,
        "filter": "glass-blur",
        "marginLeft": 0,
        "marginRight": 0,
        "marginTop": 0
      },
      "bind": {
        "fill": "_contentFill",
        "fillOpacity": "_contentOpacity"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Each player shuffles their hand and puts it on the bottom of their deck. If either player put any cards on the bottom of their deck in this way, each player draws a card for each of their remaining Prize cards.",
            "fontSize": "$trainerEffect",
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "filter": "shadow",
            "wrap": 1,
            "marginTop": 0
          },
          "bind": {
            "text": "effect",
            "fill": "_textFill"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "Play only 1 Supporter per turn.",
            "fontSize": "$ruleText",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 1,
            "marginTop": 10
          },
          "bind": {
            "text": "_ruleText",
            "fill": "_subtleFill"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "Paldea Evolved • 254",
            "fontSize": "$footer",
            "fontFamily": "infobar",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 6
          },
          "bind": {
            "text": "_footer",
            "fill": "_subtleFill"
          }
        }
      ]
    }
  ]
}
