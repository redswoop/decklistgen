{
  "id": "trainer",
  "name": "Trainer",
  "elements": [
    {
      "type": "box",
      "id": "name-cluster",
      "props": {
        "anchorX": 45,
        "anchorY": 76,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Professor's Research",
            "fontSize": "$cardName.trainer",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginTop": 0,
            "marginRight": 0,
            "marginBottom": 6,
            "marginLeft": 0,
            "paddingTop": 0,
            "paddingRight": 0,
            "paddingBottom": 0,
            "paddingLeft": 0,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "_baseName"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "subtitle",
      "props": {
        "anchorX": 47,
        "anchorY": 128,
        "direction": "row"
      },
      "showIf": "_subtitle",
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Professor Oak",
            "fontSize": "$subtitle.trainer",
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 0.6,
            "filter": "shadow",
            "wrap": 0,
            "vAlign": "middle"
          },
          "bind": {
            "text": "_subtitle"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "trainer-type",
      "props": {
        "anchorX": 30,
        "anchorY": 20,
        "direction": "row",
        "hAnchor": "right",
        "fill": "#ababab",
        "rx": 16,
        "paddingLeft": 16,
        "paddingRight": 16,
        "paddingBottom": 4,
        "paddingTop": 4,
        "strokeWidth": 3,
        "stroke": "#050505"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Supporter",
            "fontSize": "$trainerType",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#f04628",
            "opacity": 1,
            "stroke": "#ffffff",
            "strokeWidth": 4,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginTop": 0,
            "marginRight": 0,
            "marginBottom": 6,
            "marginLeft": 0,
            "paddingTop": 0,
            "paddingRight": 0,
            "paddingBottom": 0,
            "paddingLeft": 0,
            "vAlign": "bottom",
            "hAlign": "start"
          },
          "bind": {
            "text": "trainerType"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "content-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 8,
        "paddingRight": 12,
        "paddingBottom": 37,
        "paddingLeft": 12,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 5
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Discard your hand and draw 7 cards.",
            "fontSize": "$trainerEffect",
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "filter": "shadow",
            "wrap": 1,
            "marginTop": 0
          },
          "bind": {
            "text": "effect"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "Play only 1 Supporter per turn.",
            "fontSize": "$ruleText",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.6,
            "filter": "none",
            "wrap": 1,
            "marginTop": 10
          },
          "bind": {
            "text": "_ruleText"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "Celebrations • 24",
            "fontSize": "$footer",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 6
          },
          "bind": {
            "text": "_footer"
          }
        }
      ]
    }
  ]
}