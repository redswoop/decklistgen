{
  "id": "basic-energy",
  "name": "Basic Energy",
  "elements": [
    {
      "type": "box",
      "id": "name-cluster",
      "props": {
        "anchorX": 45,
        "anchorY": 76,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Fire Energy",
            "fontSize": "$cardName.trainer",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginBottom": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "_baseName",
            "fill": "_textFill",
            "stroke": "_textStroke"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "energy-type",
      "props": {
        "anchorX": 30,
        "anchorY": 20,
        "direction": "row",
        "hAnchor": "right",
        "fill": "#ababab",
        "rx": 16,
        "paddingLeft": 16,
        "paddingRight": 16,
        "paddingBottom": 4,
        "paddingTop": 4,
        "strokeWidth": 3,
        "stroke": "#050505"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Basic Energy",
            "fontSize": "$trainerType",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#f04628",
            "opacity": 1,
            "stroke": "#ffffff",
            "strokeWidth": 4,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginBottom": 6,
            "vAlign": "bottom",
            "hAlign": "start"
          },
          "bind": {
            "text": "_energyLabel"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "footer-block",
      "props": {
        "anchorX": 20,
        "anchorY": 20,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 20,
        "paddingRight": 25,
        "paddingBottom": 30,
        "paddingLeft": 25,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 25,
        "filter": "glass-blur"
      },
      "bind": {
        "fill": "_contentFill",
        "fillOpacity": "_contentOpacity"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Scarlet & Violet • 258",
            "fontSize": "$footer",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 0
          },
          "bind": {
            "text": "_footer",
            "fill": "_subtleFill"
          }
        }
      ]
    }
  ]
}
