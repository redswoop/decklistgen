{
  "id": "pokemon-fullart",
  "name": "Pokemon (Full Art)",
  "elements": [
    {
      "type": "image",
      "id": "big-logo",
      "props": {
        "src": "logo",
        "suffix": "VSTAR-big",
        "height": 280,
        "opacity": 0.85,
        "clipToCard": 1,
        "anchorX": -50,
        "anchorY": -38
      },
      "bind": {
        "suffix": "_bigLogoSuffix"
      },
      "showIf": "_bigLogoSuffix"
    },
    {
      "type": "box",
      "id": "hp-cluster",
      "props": {
        "anchorX": 514,
        "anchorY": 42,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "HP",
            "fontSize": "$hpLabel.fullart",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "filter": "none",
            "textAnchor": "start",
            "wrap": 0,
            "marginRight": 4,
            "marginBottom": 4,
            "vAlign": "bottom"
          },
          "bind": {
            "fill": "_textFill"
          }
        },
        {
          "type": "text",
          "props": {
            "text": 210,
            "fontSize": "$hp.fullart",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 0,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginRight": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "hp",
            "fill": "_textFill",
            "stroke": "_textStroke"
          }
        },
        {
          "type": "image",
          "props": {
            "src": "energy",
            "energyType": "Darkness",
            "radius": 25,
            "vAlign": "middle"
          },
          "bind": {
            "energyType": "types[0]"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "name-cluster",
      "props": {
        "anchorX": 45,
        "anchorY": 46,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Absol",
            "fontSize": "$cardName.fullart",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginBottom": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "_baseName",
            "fill": "_textFill",
            "stroke": "_textStroke"
          }
        },
        {
          "type": "image",
          "props": {
            "src": "logo",
            "suffix": "ex",
            "height": 55,
            "filter": "title-shadow",
            "marginLeft": 4,
            "vAlign": "bottom"
          },
          "bind": {
            "suffix": "_nameSuffix"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "evolves-from",
      "props": {
        "anchorX": 47,
        "anchorY": 98,
        "direction": "row"
      },
      "showIf": "evolveFrom",
      "children": [
        {
          "type": "text",
          "props": {
            "text": "",
            "fontSize": "$evolvesFrom.fullart",
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 0.8,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "vAlign": "middle",
            "stroke": "#000000",
            "strokeWidth": 2.5
          },
          "bind": {
            "text": "_evolvesFrom",
            "fill": "_textFill",
            "stroke": "_textStroke"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "content-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 15,
        "paddingRight": 15,
        "paddingBottom": 37,
        "paddingLeft": 15,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 25,
        "filter": "glass-blur",
        "blurRadius": 5,
        "marginTop": 0
      },
      "bind": {
        "fill": "_contentFill",
        "fillOpacity": "_contentOpacity"
      },
      "children": [
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "abilities"
          },
          "showIf": "abilities",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginBottom": 6
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row"
                },
                "children": [
                  {
                    "type": "text",
                    "props": {
                      "text": "Ability:",
                      "fontSize": "$abilityLabel.fullart",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ff4444",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 0,
                      "hAlign": "start",
                      "marginRight": 6,
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "type"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Ability Name",
                      "fontSize": "$abilityName.fullart",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 1,
                      "hAlign": "start",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "name",
                      "fill": "_textFill"
                    }
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Ability effect text.",
                  "fontSize": "$abilityEffect.fullart",
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "opacity": 0.9,
                  "filter": "shadow",
                  "wrap": 1,
                  "palette": "light",
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect",
                  "fill": "_textFill",
                  "palette": "_palette"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "attacks"
          },
          "showIf": "attacks",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginTop": 4
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row",
                  "marginBottom": 5,
                  "fillGradient": "ribbon"
                },
                "bind": {
                  "fill": "_ribbonColor"
                },
                "children": [
                  {
                    "type": "repeater",
                    "props": {
                      "direction": "row"
                    },
                    "bind": {
                      "items": "cost"
                    },
                    "itemTemplate": {
                      "type": "image",
                      "props": {
                        "src": "energy",
                        "energyType": "Colorless",
                        "radius": 19,
                        "grow": 0,
                        "hAlign": "start",
                        "marginRight": 4,
                        "vAlign": "middle"
                      },
                      "bind": {
                        "energyType": "$item"
                      }
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Attack Name",
                      "fontSize": "$attackName",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 1,
                      "hAlign": "start",
                      "vAlign": "middle",
                      "marginBottom": 5
                    },
                    "bind": {
                      "text": "name",
                      "fill": "_textFill"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "0",
                      "fontSize": "$damage",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#4fdedb",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 0,
                      "hAlign": "end",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "damage"
                    },
                    "showIf": "damage"
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Effect text.",
                  "fontSize": "$attackEffect.fullart",
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "opacity": 1,
                  "filter": "shadow",
                  "wrap": 1,
                  "palette": "light",
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect",
                  "fill": "_textFill",
                  "palette": "_palette"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "box",
          "props": {
            "direction": "row",
            "marginTop": 6
          },
          "children": [
            {
              "type": "text",
              "props": {
                "text": "Weak",
                "fontSize": "$label",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "filter": "none",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Grass",
                "radius": 12,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "weaknesses[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "×2",
                "fontSize": "$multiplier",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 16,
                "vAlign": "middle"
              },
              "bind": {
                "text": "weaknesses[0].value",
                "fill": "_textFill"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Resist",
                "fontSize": "$label",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "filter": "none",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Grass",
                "radius": 12,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "resistances[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "-30",
                "fontSize": "$multiplier",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 1,
                "hAlign": "start",
                "vAlign": "middle"
              },
              "bind": {
                "text": "resistances[0].value",
                "fill": "_textFill"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Retreat",
                "fontSize": "$label",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "filter": "none",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "repeater",
              "props": {
                "direction": "row"
              },
              "bind": {
                "items": "_retreatDots"
              },
              "itemTemplate": {
                "type": "image",
                "props": {
                  "src": "energy",
                  "energyType": "Colorless",
                  "radius": 12,
                  "grow": 0,
                  "hAlign": "start",
                  "marginRight": 4,
                  "vAlign": "middle"
                }
              }
            }
          ]
        },
        {
          "type": "text",
          "props": {
            "text": "When this ex is KO'd, opponent takes 2 Prizes.",
            "fontSize": "$ruleText",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.6,
            "filter": "none",
            "wrap": 1,
            "marginTop": 6
          },
          "bind": {
            "text": "_ruleText",
            "fill": "_subtleFill"
          },
          "showIf": "_ruleText"
        },
        {
          "type": "text",
          "props": {
            "text": "Obsidian Flames • 214",
            "fontSize": "$footer",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 4
          },
          "bind": {
            "text": "_footer",
            "fill": "_subtleFill"
          }
        }
      ]
    }
  ]
}