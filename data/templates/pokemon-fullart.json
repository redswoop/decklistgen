{
  "id": "pokemon-fullart",
  "name": "Pokemon (Full Art)",
  "description": "Full-art Pokemon card \u2014 data-driven attacks, abilities, energy costs via repeaters",
  "elements": [
    {
      "type": "image",
      "id": "big-logo",
      "props": {
        "src": "logo",
        "suffix": "VSTAR-big",
        "height": 280,
        "opacity": 0.85,
        "clipToCard": 1,
        "anchorX": -50,
        "anchorY": -38
      },
      "bind": {
        "suffix": "_bigLogoSuffix"
      }
    },
    {
      "type": "box",
      "id": "hp-cluster",
      "props": {
        "anchorX": 514,
        "anchorY": 42,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "HP",
            "fontSize": 25,
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "filter": "none",
            "textAnchor": "start",
            "wrap": 0,
            "marginRight": 4,
            "marginBottom": 4,
            "vAlign": "bottom"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "280",
            "fontSize": 52,
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 0,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginRight": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "hp"
          }
        },
        {
          "type": "image",
          "props": {
            "src": "energy",
            "energyType": "Fire",
            "radius": 25,
            "vAlign": "middle"
          },
          "bind": {
            "energyType": "types[0]"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "name-cluster",
      "props": {
        "anchorX": 45,
        "anchorY": 46,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Arcanine",
            "fontSize": 48,
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "marginBottom": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "_baseName"
          }
        },
        {
          "type": "image",
          "props": {
            "src": "logo",
            "suffix": "ex",
            "height": 55,
            "filter": "title-shadow",
            "marginLeft": 4,
            "vAlign": "bottom"
          },
          "bind": {
            "suffix": "_nameSuffix"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "stage-line",
      "props": {
        "anchorX": 47,
        "anchorY": 98,
        "direction": "row"
      },
      "showIf": "evolveFrom",
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Stage 1 \u2014 Evolves from Growlithe",
            "fontSize": 18,
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 0.7,
            "filter": "shadow",
            "textAnchor": "start",
            "wrap": 0,
            "vAlign": "middle"
          },
          "bind": {
            "text": "_stageLabel"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "content-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 4,
        "paddingRight": 8,
        "paddingBottom": 37,
        "paddingLeft": 8,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 5
      },
      "children": [
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "abilities"
          },
          "showIf": "abilities",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginBottom": 6
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row"
                },
                "children": [
                  {
                    "type": "text",
                    "props": {
                      "text": "Ability:",
                      "fontSize": 22,
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ff4444",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 0,
                      "hAlign": "start",
                      "marginRight": 6,
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "type"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Ability Name",
                      "fontSize": 22,
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 1,
                      "hAlign": "start",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "name"
                    }
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Ability effect text.",
                  "fontSize": 20,
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "opacity": 0.9,
                  "filter": "shadow",
                  "wrap": 1,
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "attacks"
          },
          "showIf": "attacks",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginTop": 4
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row"
                },
                "children": [
                  {
                    "type": "repeater",
                    "props": {
                      "direction": "row"
                    },
                    "bind": {
                      "items": "cost"
                    },
                    "itemTemplate": {
                      "type": "image",
                      "props": {
                        "src": "energy",
                        "energyType": "Colorless",
                        "radius": 14,
                        "grow": 0,
                        "hAlign": "start",
                        "marginRight": 4,
                        "vAlign": "middle"
                      },
                      "bind": {
                        "energyType": "$item"
                      }
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Attack Name",
                      "fontSize": 28,
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 1,
                      "hAlign": "start",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "name"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "0",
                      "fontSize": 36,
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#cc0000",
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 0,
                      "hAlign": "end",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "damage"
                    },
                    "showIf": "damage"
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Effect text.",
                  "fontSize": 20,
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "opacity": 1,
                  "filter": "shadow",
                  "wrap": 1,
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "box",
          "props": {
            "direction": "row",
            "marginTop": 6
          },
          "children": [
            {
              "type": "text",
              "props": {
                "text": "Weak",
                "fontSize": 14,
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "filter": "none",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Lightning",
                "radius": 12,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "weaknesses[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "\u00d72",
                "fontSize": 22,
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 16,
                "vAlign": "middle"
              },
              "bind": {
                "text": "weaknesses[0].value"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Resist",
                "fontSize": 14,
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "filter": "none",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Fighting",
                "radius": 12,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "resistances[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "-30",
                "fontSize": 22,
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 1,
                "hAlign": "start",
                "vAlign": "middle"
              },
              "bind": {
                "text": "resistances[0].value"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Retreat",
                "fontSize": 14,
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "filter": "none",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "repeater",
              "props": {
                "direction": "row"
              },
              "bind": {
                "items": "_retreatDots"
              },
              "itemTemplate": {
                "type": "image",
                "props": {
                  "src": "energy",
                  "energyType": "Colorless",
                  "radius": 12,
                  "grow": 0,
                  "hAlign": "start",
                  "marginRight": 4,
                  "vAlign": "middle"
                }
              }
            }
          ]
        },
        {
          "type": "text",
          "props": {
            "text": "When this ex is KO'd, opponent takes 2 Prizes.",
            "fontSize": 16,
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.6,
            "filter": "none",
            "wrap": 1,
            "marginTop": 6
          },
          "bind": {
            "text": "_ruleText"
          },
          "showIf": "_ruleText"
        },
        {
          "type": "text",
          "props": {
            "text": "Set Name \u2022 001",
            "fontSize": 14,
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 4
          },
          "bind": {
            "text": "_footer"
          }
        }
      ]
    }
  ]
}
