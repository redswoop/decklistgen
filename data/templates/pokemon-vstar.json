{
  "id": "pokemon-vstar",
  "name": "Pokemon (VSTAR)",
  "description": "VSTAR Pokemon \u2014 fullart with VSTAR logo, data-driven attacks then VSTAR Power with gold accent",
  "elements": [
    {
      "type": "image",
      "id": "big-logo",
      "props": {
        "src": "logo",
        "suffix": "VSTAR-big",
        "height": 280,
        "opacity": 0.7,
        "clipToCard": 1,
        "anchorX": -50,
        "anchorY": -38
      }
    },
    {
      "type": "box",
      "id": "hp-cluster",
      "props": {
        "anchorX": 514,
        "anchorY": 42,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "HP",
            "fontSize": "$hpLabel.fullart",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "filter": "none",
            "wrap": 0,
            "marginRight": 4,
            "marginBottom": 4,
            "vAlign": "bottom"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "280",
            "fontSize": "$hp.fullart",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "stroke": "#000000",
            "strokeWidth": 0,
            "filter": "title-shadow",
            "wrap": 0,
            "marginRight": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "hp"
          }
        },
        {
          "type": "image",
          "props": {
            "src": "energy",
            "energyType": "Fire",
            "radius": 25,
            "vAlign": "middle"
          },
          "bind": {
            "energyType": "types[0]"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "name-cluster",
      "props": {
        "anchorX": 45,
        "anchorY": 46,
        "direction": "row"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Charizard",
            "fontSize": "$cardName.fullart",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "wrap": 0,
            "marginBottom": 6,
            "vAlign": "bottom"
          },
          "bind": {
            "text": "_baseName"
          }
        },
        {
          "type": "image",
          "props": {
            "src": "logo",
            "suffix": "VSTAR",
            "height": 55,
            "filter": "title-shadow",
            "marginLeft": 4,
            "vAlign": "bottom"
          },
          "bind": {
            "suffix": "_nameSuffix"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "evolves-from",
      "props": {
        "anchorX": 47,
        "anchorY": 98,
        "direction": "row"
      },
      "showIf": "evolveFrom",
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Evolves from X",
            "fontSize": "$evolvesFrom.vstar",
            "fontFamily": "body",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 0.7,
            "filter": "shadow",
            "wrap": 0,
            "vAlign": "middle"
          },
          "bind": {
            "text": "_evolvesFrom"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "content-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 4,
        "paddingRight": 8,
        "paddingBottom": 37,
        "paddingLeft": 8,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 5
      },
      "children": [
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "attacks"
          },
          "showIf": "attacks",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginTop": 4
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row"
                },
                "children": [
                  {
                    "type": "repeater",
                    "props": {
                      "direction": "row"
                    },
                    "bind": {
                      "items": "cost"
                    },
                    "itemTemplate": {
                      "type": "image",
                      "props": {
                        "src": "energy",
                        "energyType": "Colorless",
                        "radius": 19,
                        "grow": 0,
                        "marginRight": 4,
                        "vAlign": "middle"
                      },
                      "bind": {
                        "energyType": "$item"
                      }
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Attack",
                      "fontSize": "$attackName",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "filter": "shadow",
                      "wrap": 0,
                      "grow": 1,
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "name"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "0",
                      "fontSize": "$damage",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#cc0000",
                      "filter": "shadow",
                      "wrap": 0,
                      "grow": 0,
                      "hAlign": "end",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "damage"
                    },
                    "showIf": "damage"
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Effect.",
                  "fontSize": "$attackEffect",
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "filter": "shadow",
                  "wrap": 1,
                  "palette": "light",
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "text",
          "props": {
            "text": "VSTAR Power",
            "fontSize": "$vstarPowerLabel",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#DAA520",
            "filter": "shadow",
            "wrap": 0,
            "marginTop": 10
          },
          "showIf": "abilities"
        },
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "abilities"
          },
          "showIf": "abilities",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginTop": 2
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row"
                },
                "children": [
                  {
                    "type": "text",
                    "props": {
                      "text": "Ability:",
                      "fontSize": "$abilityLabel",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#DAA520",
                      "filter": "shadow",
                      "wrap": 0,
                      "grow": 0,
                      "marginRight": 6,
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "type"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Name",
                      "fontSize": "$abilityName",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "filter": "shadow",
                      "wrap": 0,
                      "grow": 1,
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "name"
                    }
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Effect.",
                  "fontSize": "$abilityEffect",
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "opacity": 0.9,
                  "filter": "shadow",
                  "wrap": 1,
                  "palette": "light",
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "box",
          "props": {
            "direction": "row",
            "marginTop": 6
          },
          "children": [
            {
              "type": "text",
              "props": {
                "text": "Weak",
                "fontSize": "$label",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "wrap": 0,
                "grow": 0,
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Water",
                "radius": 12,
                "grow": 0,
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "weaknesses[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "\u00d72",
                "fontSize": "$multiplier",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "filter": "shadow",
                "wrap": 0,
                "grow": 0,
                "marginRight": 16,
                "vAlign": "middle"
              },
              "bind": {
                "text": "weaknesses[0].value"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Resist",
                "fontSize": "$label",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "wrap": 0,
                "grow": 0,
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Fighting",
                "radius": 12,
                "grow": 0,
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "resistances[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "-30",
                "fontSize": "$multiplier",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "filter": "shadow",
                "wrap": 0,
                "grow": 1,
                "vAlign": "middle"
              },
              "bind": {
                "text": "resistances[0].value"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Retreat",
                "fontSize": "$label",
                "fontFamily": "body",
                "fontWeight": "bold",
                "fill": "#888888",
                "wrap": 0,
                "grow": 0,
                "marginRight": 4,
                "vAlign": "middle"
              }
            },
            {
              "type": "repeater",
              "props": {
                "direction": "row"
              },
              "bind": {
                "items": "_retreatDots"
              },
              "itemTemplate": {
                "type": "image",
                "props": {
                  "src": "energy",
                  "energyType": "Colorless",
                  "radius": 12,
                  "grow": 0,
                  "marginRight": 4,
                  "vAlign": "middle"
                }
              }
            }
          ]
        },
        {
          "type": "text",
          "props": {
            "text": "Rule text.",
            "fontSize": "$ruleText",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.6,
            "wrap": 1,
            "marginTop": 6
          },
          "bind": {
            "text": "_ruleText"
          },
          "showIf": "_ruleText"
        },
        {
          "type": "text",
          "props": {
            "text": "Set \u2022 001",
            "fontSize": "$footer",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "wrap": 0,
            "marginTop": 4
          },
          "bind": {
            "text": "_footer"
          }
        }
      ]
    }
  ]
}
