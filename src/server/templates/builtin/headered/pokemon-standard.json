{
  "id": "pokemon-standard",
  "name": "Pokemon Standard (Headered)",
  "description": "Standard Pokemon with a top header pill containing name, evolves-from, and HP for legibility against any artwork.",
  "elements": [
    {
      "type": "box",
      "id": "header-pill",
      "props": {
        "anchorX": 20,
        "anchorY": 18,
        "width": 710,
        "direction": "row",
        "fill": "#0a0a0a",
        "fillGradient": "metallic-trainer-default",
        "fillOpacity": 0.9,
        "rx": 20,
        "paddingLeft": 28,
        "paddingRight": 24,
        "paddingTop": 10,
        "paddingBottom": 10,
        "filter": "title-shadow"
      },
      "children": [
        {
          "type": "box",
          "id": "header-name-stack",
          "props": {
            "direction": "column",
            "grow": 1,
            "vAlign": "middle"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "text": "",
                "fontSize": "$evolvesFrom.fullart",
                "fontFamily": "infobar",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "opacity": 0.7,
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "title-shadow",
                "wrap": 0,
                "hAlign": "start"
              },
              "bind": {
                "text": "_evolvesFrom",
                "fill": "_textFill",
                "stroke": "_textStroke"
              },
              "showIf": "evolveFrom"
            },
            {
              "type": "box",
              "id": "header-name-row",
              "props": {
                "direction": "row",
                "vAlign": "middle"
              },
              "children": [
                {
                  "type": "text",
                  "props": {
                    "text": "Charizard",
                    "fontSize": "$cardName.fullart",
                    "fontFamily": "title",
                    "fontWeight": "bold",
                    "fill": "#ffffff",
                    "opacity": 1,
                    "stroke": "#000000",
                    "strokeWidth": 2.5,
                    "filter": "title-shadow",
                    "wrap": 0,
                    "hAlign": "start",
                    "vAlign": "middle"
                  },
                  "bind": {
                    "text": "_baseName",
                    "fill": "_textFill",
                    "stroke": "_textStroke"
                  }
                },
                {
                  "type": "image",
                  "props": {
                    "src": "logo",
                    "suffix": "ex",
                    "height": 48,
                    "filter": "title-shadow",
                    "marginLeft": 6,
                    "vAlign": "middle"
                  },
                  "bind": {
                    "suffix": "_nameSuffix"
                  },
                  "showIf": "_nameSuffix"
                }
              ]
            }
          ]
        },
        {
          "type": "box",
          "id": "header-hp-cluster",
          "props": {
            "direction": "row",
            "hAlign": "end",
            "vAlign": "middle"
          },
          "children": [
            {
              "type": "text",
              "props": {
                "text": "HP",
                "fontSize": "$hpLabel.fullart",
                "fontFamily": "hp",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "opacity": 1,
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "none",
                "wrap": 0,
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "fill": "_hpTextFill",
                "stroke": "_hpTextStroke"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "120",
                "fontSize": "$hp.fullart",
                "fontFamily": "hp",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "opacity": 1,
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "title-shadow",
                "wrap": 0,
                "marginRight": 6,
                "vAlign": "middle"
              },
              "bind": {
                "text": "hp",
                "fill": "_hpTextFill",
                "stroke": "_hpTextStroke"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Fire",
                "radius": 21,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "types[0]"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "box",
      "id": "content-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 15,
        "paddingRight": 15,
        "paddingBottom": 37,
        "paddingLeft": 15,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 25,
        "filter": "glass-blur",
        "blurRadius": 5,
        "marginTop": 0
      },
      "bind": {
        "fill": "_contentFill",
        "fillOpacity": "_contentOpacity"
      },
      "children": [
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "abilities"
          },
          "showIf": "abilities",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginBottom": 6
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row"
                },
                "children": [
                  {
                    "type": "box",
                    "props": {
                      "direction": "row",
                      "paddingTop": 3,
                      "paddingBottom": 3,
                      "paddingLeft": 14,
                      "paddingRight": 14,
                      "rx": 14,
                      "fill": "#d4a017",
                      "fillGradient": "ability-pill-gold-red",
                      "filter": "title-shadow",
                      "marginRight": 8,
                      "vAlign": "middle"
                    },
                    "children": [
                      {
                        "type": "text",
                        "props": {
                          "text": "Ability",
                          "fontSize": "$abilityPill.fullart",
                          "fontFamily": "title",
                          "fontWeight": "bold",
                          "fontStyle": "italic",
                          "fill": "#ffffff",
                          "stroke": "#000000",
                          "strokeWidth": 1.5,
                          "filter": "shadow",
                          "vAlign": "middle",
                          "wrap": 0
                        }
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Ability Name",
                      "fontSize": "$abilityName.fullart",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "stroke": "#000000",
                      "strokeWidth": 2.5,
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 1,
                      "hAlign": "start",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "name",
                      "fill": "_textFill",
                      "stroke": "_textStroke",
                      "strokeWidth": "_textStrokeWidth"
                    }
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Ability effect text.",
                  "fontSize": "$abilityEffect.fullart",
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "stroke": "#000000",
                  "strokeWidth": 2.5,
                  "opacity": 1,
                  "filter": "shadow",
                  "wrap": 1,
                  "palette": "light",
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect",
                  "fill": "_textFill",
                  "stroke": "_textStroke",
                  "strokeWidth": "_textStrokeWidth",
                  "palette": "_palette"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "repeater",
          "props": {
            "direction": "column"
          },
          "bind": {
            "items": "attacks"
          },
          "showIf": "attacks",
          "itemTemplate": {
            "type": "box",
            "props": {
              "direction": "column",
              "marginTop": 4
            },
            "children": [
              {
                "type": "box",
                "props": {
                  "direction": "row",
                  "marginBottom": 5,
                  "fillGradient": "ribbon"
                },
                "bind": {
                  "fill": "_ribbonColor"
                },
                "children": [
                  {
                    "type": "repeater",
                    "props": {
                      "direction": "row"
                    },
                    "bind": {
                      "items": "cost"
                    },
                    "itemTemplate": {
                      "type": "image",
                      "props": {
                        "src": "energy",
                        "energyType": "Colorless",
                        "radius": 19,
                        "grow": 0,
                        "hAlign": "start",
                        "marginRight": 4,
                        "vAlign": "middle"
                      },
                      "bind": {
                        "energyType": "$item"
                      }
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "Attack Name",
                      "fontSize": "$attackName",
                      "fontFamily": "title",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "stroke": "#000000",
                      "strokeWidth": 2.5,
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 1,
                      "hAlign": "start",
                      "vAlign": "middle",
                      "marginBottom": 5
                    },
                    "bind": {
                      "text": "name",
                      "fill": "_textFill",
                      "stroke": "_textStroke",
                      "strokeWidth": "_textStrokeWidth"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "text": "0",
                      "fontSize": "$damage",
                      "fontFamily": "hp",
                      "fontWeight": "bold",
                      "fill": "#ffffff",
                      "stroke": "#000000",
                      "strokeWidth": 2,
                      "filter": "shadow",
                      "textAnchor": "start",
                      "wrap": 0,
                      "grow": 0,
                      "hAlign": "end",
                      "vAlign": "middle"
                    },
                    "bind": {
                      "text": "damage",
                      "fill": "_textFill",
                      "stroke": "_textStroke"
                    },
                    "showIf": "damage"
                  }
                ]
              },
              {
                "type": "text",
                "props": {
                  "text": "Effect text.",
                  "fontSize": "$attackEffect.fullart",
                  "fontFamily": "body",
                  "fontWeight": "bold",
                  "fill": "#ffffff",
                  "stroke": "#000000",
                  "strokeWidth": 2.5,
                  "opacity": 1,
                  "filter": "shadow",
                  "wrap": 1,
                  "palette": "light",
                  "marginTop": 4
                },
                "bind": {
                  "text": "effect",
                  "fill": "_textFill",
                  "stroke": "_textStroke",
                  "strokeWidth": "_textStrokeWidth",
                  "palette": "_palette"
                },
                "showIf": "effect"
              }
            ]
          }
        },
        {
          "type": "box",
          "props": {
            "direction": "row",
            "marginTop": 6
          },
          "children": [
            {
              "type": "text",
              "props": {
                "text": "Weak",
                "fontSize": "$label",
                "fontFamily": "infobar",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "opacity": 0.7,
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "fill": "_textFill",
                "stroke": "_textStroke"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Grass",
                "radius": 12,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "weaknesses[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "×2",
                "fontSize": "$multiplier",
                "fontFamily": "infobar",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 16,
                "vAlign": "middle"
              },
              "bind": {
                "text": "weaknesses[0].value",
                "fill": "_textFill",
                "stroke": "_textStroke"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Resist",
                "fontSize": "$label",
                "fontFamily": "infobar",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "opacity": 0.7,
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "fill": "_textFill",
                "stroke": "_textStroke"
              }
            },
            {
              "type": "image",
              "props": {
                "src": "energy",
                "energyType": "Grass",
                "radius": 12,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "energyType": "resistances[0].type"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "-30",
                "fontSize": "$multiplier",
                "fontFamily": "infobar",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 1,
                "hAlign": "start",
                "vAlign": "middle"
              },
              "bind": {
                "text": "resistances[0].value",
                "fill": "_textFill",
                "stroke": "_textStroke"
              }
            },
            {
              "type": "text",
              "props": {
                "text": "Retreat",
                "fontSize": "$label",
                "fontFamily": "infobar",
                "fontWeight": "bold",
                "fill": "#ffffff",
                "opacity": 0.7,
                "stroke": "#000000",
                "strokeWidth": 2.5,
                "filter": "shadow",
                "textAnchor": "start",
                "wrap": 0,
                "grow": 0,
                "hAlign": "start",
                "marginRight": 4,
                "vAlign": "middle"
              },
              "bind": {
                "fill": "_textFill",
                "stroke": "_textStroke"
              }
            },
            {
              "type": "repeater",
              "props": {
                "direction": "row"
              },
              "bind": {
                "items": "_retreatDots"
              },
              "itemTemplate": {
                "type": "image",
                "props": {
                  "src": "energy",
                  "energyType": "Colorless",
                  "radius": 12,
                  "grow": 0,
                  "hAlign": "start",
                  "marginRight": 4,
                  "vAlign": "middle"
                }
              }
            }
          ]
        },
        {
          "type": "text",
          "props": {
            "text": "Rule text.",
            "fontSize": "$ruleText",
            "fontFamily": "body",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 1,
            "marginTop": 6
          },
          "bind": {
            "text": "_ruleText",
            "fill": "_subtleFill"
          },
          "showIf": "_ruleText"
        },
        {
          "type": "text",
          "props": {
            "text": "Set • 001",
            "fontSize": "$footer",
            "fontFamily": "infobar",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 4
          },
          "bind": {
            "text": "_footer",
            "fill": "_subtleFill"
          }
        }
      ]
    }
  ]
}
