{
  "id": "basic-energy",
  "name": "Basic Energy (Headered)",
  "elements": [
    {
      "type": "box",
      "id": "header-pill",
      "props": {
        "anchorX": 20,
        "anchorY": 20,
        "width": 710,
        "direction": "row",
        "fill": "#0a0a0a",
        "fillGradient": "metallic-trainer-default",
        "fillOpacity": 0.92,
        "rx": 20,
        "paddingLeft": 28,
        "paddingRight": 28,
        "paddingTop": 10,
        "paddingBottom": 10,
        "filter": "title-shadow"
      },
      "bind": {
        "fillGradient": "_trainerGradient"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Basic Energy",
            "fontSize": "$trainerType",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fontStyle": "italic",
            "fill": "#ffffff",
            "opacity": 0.7,
            "stroke": "#000000",
            "strokeWidth": 2,
            "filter": "title-shadow",
            "wrap": 0,
            "grow": 0,
            "marginRight": 12,
            "hAlign": "start",
            "vAlign": "middle"
          },
          "bind": {
            "text": "_energyLabel"
          }
        },
        {
          "type": "text",
          "props": {
            "text": "Fire Energy",
            "fontSize": "$cardName.trainer",
            "fontFamily": "title",
            "fontWeight": "bold",
            "fill": "#ffffff",
            "opacity": 1,
            "stroke": "#000000",
            "strokeWidth": 2.5,
            "filter": "title-shadow",
            "textAnchor": "start",
            "wrap": 0,
            "grow": 1,
            "hAlign": "end",
            "vAlign": "middle"
          },
          "bind": {
            "text": "_baseName",
            "fill": "_textFill",
            "stroke": "_textStroke"
          }
        }
      ]
    },
    {
      "type": "box",
      "id": "footer-block",
      "props": {
        "anchorX": 20,
        "anchorY": 0,
        "width": 710,
        "direction": "column",
        "vAnchor": "bottom",
        "paddingTop": 15,
        "paddingRight": 15,
        "paddingBottom": 37,
        "paddingLeft": 15,
        "fill": "#000000",
        "fillOpacity": 0.15,
        "rx": 25,
        "filter": "glass-blur"
      },
      "bind": {
        "fill": "_contentFill",
        "fillOpacity": "_contentOpacity"
      },
      "children": [
        {
          "type": "text",
          "props": {
            "text": "Scarlet & Violet • 258",
            "fontSize": "$footer",
            "fontFamily": "infobar",
            "fontWeight": "normal",
            "fill": "#ffffff",
            "opacity": 0.5,
            "filter": "none",
            "wrap": 0,
            "marginTop": 0
          },
          "bind": {
            "text": "_footer",
            "fill": "_subtleFill"
          }
        }
      ]
    }
  ]
}
