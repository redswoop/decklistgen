{
  "name": "decklistgen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently 'bun run dev:server' 'bun run dev:client'",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "vite src/client",
    "build": "vite build && bun build src/server/index.ts --outdir dist/server --target bun",
    "start": "bun dist/server/index.js",
    "cli": "bun cli/index.ts",
    "test": "bun test",
    "test:e2e": "bunx playwright test",
    "deploy": "git push && docker buildx build --platform linux/amd64 --build-arg CACHEBUST=$(date +%s) -t skywarp75/decklistgen:latest --push ."
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tanstack/vue-query": "^5.67.0",
    "@tanstack/vue-virtual": "^3.13.21",
    "hono": "^4.7.0",
    "opentype.js": "^1.3.4",
    "splitpanes": "^3.1.7",
    "vue": "^3.5.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  }
}
